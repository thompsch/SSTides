<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:map="clr-namespace:Syncfusion.Maui.Maps;assembly=Syncfusion.Maui.Maps"
             xmlns:models="clr-namespace:SalishSeaTides.Models"
             xmlns:behaviors="clr-namespace:SalishSeaTides.Behaviors"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="SalishSeaTides.MapPage"
             x:Name="MyMapPage">
    <Grid RowDefinitions="4*,5*"
          ColumnDefinitions="*">
        <map:SfMaps Grid.Row="0">
            <map:SfMaps.Layer>
                <map:MapTileLayer UrlTemplate="https://tile.openstreetmap.org/{z}/{x}/{y}.png"
                                  Markers="{Binding MarkerCollection}"
                                  ShowMarkerTooltip="True"
                                  behaviors:MarkerCommand.Command="{Binding MarkerSelectedCommand}">
                    <map:MapTileLayer.MarkerTemplate>
<DataTemplate>
        <!-- 1. The Fixed Anchor Core -->
        <!-- Forcing a 1x1 pixel size guarantees Syncfusion anchors this exact spot to the map. -->
        <!-- Since the parent size is fixed at 1px, text length can NEVER shift this grid. -->
        <Grid HorizontalOptions="Center" 
              VerticalOptions="Center"
              WidthRequest="1"
              HeightRequest="1"
              IsClippedToBounds="False"> 
            
            <!-- 2. The Absolute Flow Layout Container -->
            <!-- We shift this layout left by exactly half the Ellipse width (8px) using a negative margin. -->
            <!-- This ensures the true center of the 16px Ellipse aligns perfectly with our 1px anchor core. -->
            <HorizontalStackLayout VerticalOptions="Center"
                                   Spacing="6"
                                   Margin="-8,0,0,0"
                                   IsClippedToBounds="False">
                
                <!-- 3. THE ANCHOR POINT (Stays perfectly fixed on its true map spot) --> 
                <Ellipse Fill="{StaticResource PrimaryDark}" 
                         Stroke="{StaticResource Primary}" 
                         StrokeThickness="1" 
                         WidthRequest="16" 
                         HeightRequest="16" 
                         VerticalOptions="Center"/> 
                         
                <!-- 4. THE VISIBLE TEXT LABEL (Dynamic width, zero truncation) --> 
                <!-- Because it has no WidthRequest, it hugs the text length perfectly. -->
                <!-- Because the root grid size is locked at 1px, long words will never push the Ellipse. -->
                <Border Stroke="Black" 
                        StrokeThickness="0" 
                        BackgroundColor="{StaticResource LowTide}" 
                        VerticalOptions="Center"> 
                    <Border.StrokeShape> 
                        <RoundRectangle CornerRadius="2"/> 
                    </Border.StrokeShape> 
                    <Label Text="{Binding Label}" 
                           TextColor="{StaticResource PrimaryDark}" 
                           FontAttributes="Bold" 
                           FontSize="11" 
                           LineBreakMode="NoWrap"
                           HeightRequest="16"
                           VerticalOptions="Center" /> 
                </Border> 
                
            </HorizontalStackLayout>
        </Grid>
    </DataTemplate>
                    </map:MapTileLayer.MarkerTemplate>
                    <map:MapTileLayer.ZoomPanBehavior>
                        <map:MapZoomPanBehavior ZoomLevel="9"
                                                EnablePanning="True"
                                                EnableZooming="True"
                                                EnableDoubleTapZooming="True"/>
                    </map:MapTileLayer.ZoomPanBehavior>
                    <map:MapTileLayer.Center>
                        <map:MapLatLng Latitude="48.35"
                                       Longitude="-122.8">
                        </map:MapLatLng>
                    </map:MapTileLayer.Center>
                </map:MapTileLayer>
            </map:SfMaps.Layer>
        </map:SfMaps>
        <!-- List View -->
        <CollectionView Grid.Row="1"
                  ItemsSource="{Binding MarkerCollection}"
                  Margin="5,10,5,0"
                  >
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Station">
                    <Border Stroke="{StaticResource PrimaryDark}"
                            StrokeThickness="2"
                            HorizontalOptions="FillAndExpand"
                            VerticalOptions="FillAndExpand"
                            Padding="5,2"
                            Margin="0,2"
                            BackgroundColor="{StaticResource LowTide}"
                            >
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="2"/>
                        </Border.StrokeShape>
                    <Grid BackgroundColor="Transparent" ColumnDefinitions="*,*,*" >
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={x:Reference MyMapPage}, Path=BindingContext.ItemTappedCommand}"
                                    CommandParameter="{Binding .}"/>
                            </Grid.GestureRecognizers>
                                <Label Grid.Column="0"  Text="{Binding Label}" FontAttributes="Bold"/>
                                <Label Grid.Column="1" Text="{Binding Latitude, StringFormat='Lat: {0}'}"/>
                                <Label Grid.Column="2" Text="{Binding Longitude, StringFormat='Lon: {0}'}"/>
                        </Grid>
</Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>