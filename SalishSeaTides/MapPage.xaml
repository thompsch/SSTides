<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:map="clr-namespace:Syncfusion.Maui.Maps;assembly=Syncfusion.Maui.Maps"
             xmlns:models="clr-namespace:SalishSeaTides.Models"
             xmlns:behaviors="clr-namespace:SalishSeaTides.Behaviors"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="SalishSeaTides.MapPage"
             x:Name="MyMapPage">
    <Grid RowDefinitions="4*,5*"
          ColumnDefinitions="*">
        <map:SfMaps Grid.Row="0">
            <map:SfMaps.Layer>
                <map:MapTileLayer UrlTemplate="https://tile.openstreetmap.org/{z}/{x}/{y}.png"
                                  Markers="{Binding MarkerCollection}"
                                  ShowMarkerTooltip="True"
                                  behaviors:MarkerCommand.Command="{Binding MarkerSelectedCommand}">
                    <map:MapTileLayer.MarkerTemplate>
                        <DataTemplate>
                            <!-- 1. Define anchor points so Syncfusion knows the Ellipse is at the absolute left-center (0.0, 0.5) -->
                            <!-- WidthRequest="300" ensures long text fields have plenty of room to stretch to the right -->
                            <Grid HorizontalOptions="Center" VerticalOptions="Center">
            <Grid.ColumnDefinitions>
                <!-- Column 0: Left Spacer (Matches the exact width of your Label block dynamically) -->
                <ColumnDefinition Width="*" />
                <!-- Column 1: The true center anchor point where your Ellipse lives -->
                <ColumnDefinition Width="16" />
                <!-- Column 2: Right Content (Matches the exact width of your Label block dynamically) -->
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 1. THE ANCHOR POINT (Locked strictly to the center column) --> 
            <!-- Because Column 0 and Column 2 use proportional '*' sizing, Column 1 is always forced precisely onto the map coordinate -->
            <Ellipse Grid.Column="1"
                     Fill="{StaticResource PrimaryDark}" 
                     Stroke="{StaticResource HighTide}" 
                     StrokeThickness="1" 
                     WidthRequest="16" 
                     HeightRequest="16" 
                     HorizontalOptions="Center" 
                     VerticalOptions="Center"/> 
                     
            <!-- 2. THE VISIBLE TEXT LABEL (Sits in Column 2, expanding outward to the right) --> 
            <Border Grid.Column="2"
                    Stroke="Black" 
                    StrokeThickness="0" 
                    BackgroundColor="{StaticResource LowTide}" 
                    VerticalOptions="Center"
                    HorizontalOptions="Start"
                    Margin="6,0,0,0"> 
                <Border.StrokeShape> 
                    <RoundRectangle CornerRadius="2"/> 
                </Border.StrokeShape> 
                <!-- Text will grow seamlessly without truncation since its column is set to '*' -->
                <Label Text="{Binding Label}" 
                       TextColor="{StaticResource PrimaryDark}" 
                       FontAttributes="Bold" 
                       FontSize="11" 
                       HorizontalOptions="Start" 
                       VerticalOptions="Center" /> 
            </Border> 

            <!-- 3. THE INVISIBLE BALANCE SPACER (Sits in Column 0) -->
            <!-- This ghost label mirrors the exact text bounds on the left side, forcing the Grid to expand equally in both directions -->
            <!-- This ensures the center point of the Grid never leaves the center of the Ellipse -->
            <Label Grid.Column="0"
                   Text="{Binding Label}" 
                   FontSize="11" 
                   Opacity="0" 
                   InputTransparent="True"
                   HorizontalOptions="End" 
                   VerticalOptions="Center"
                   Margin="-4,0,6,0" />
                   </Grid>
                        </DataTemplate>
                    </map:MapTileLayer.MarkerTemplate>
                    <map:MapTileLayer.ZoomPanBehavior>
                        <map:MapZoomPanBehavior ZoomLevel="9"
                                                EnablePanning="True"
                                                EnableZooming="True"
                                                EnableDoubleTapZooming="True"/>
                    </map:MapTileLayer.ZoomPanBehavior>
                    <map:MapTileLayer.Center>
                        <map:MapLatLng Latitude="48.35"
                                       Longitude="-122.8">
                        </map:MapLatLng>
                    </map:MapTileLayer.Center>
                </map:MapTileLayer>
            </map:SfMaps.Layer>
        </map:SfMaps>
        <!-- List View -->
        <CollectionView Grid.Row="1"
                  ItemsSource="{Binding MarkerCollection}"
                  Margin="5,10,5,0"
                  >
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Station">
                    <Border Stroke="{StaticResource PrimaryDark}"
                            StrokeThickness="2"
                            HorizontalOptions="FillAndExpand"
                            VerticalOptions="FillAndExpand"
                            Padding="5,2"
                            Margin="0,2"
                            BackgroundColor="{StaticResource LowTide}"
                            >
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="2"/>
                        </Border.StrokeShape>
                    <Grid BackgroundColor="Transparent" ColumnDefinitions="*,*,*" >
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={x:Reference MyMapPage}, Path=BindingContext.ItemTappedCommand}"
                                    CommandParameter="{Binding .}"/>
                            </Grid.GestureRecognizers>
                                <Label Grid.Column="0"  Text="{Binding Label}" FontAttributes="Bold"/>
                                <Label Grid.Column="1" Text="{Binding Latitude, StringFormat='Lat: {0}'}"/>
                                <Label Grid.Column="2" Text="{Binding Longitude, StringFormat='Lon: {0}'}"/>
                        </Grid>
</Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>